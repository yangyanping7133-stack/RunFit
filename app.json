{
  "expo": {
    "name": "RunFit",
    "slug": "runfit",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "scheme": "runfit",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.runfit.app"
    },
    "android": {
      "package": "com.runfit.app",
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": []
  }
}
